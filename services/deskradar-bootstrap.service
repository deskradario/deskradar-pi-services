[Unit]
Description=Deskradar Boot Check Service
After=local-fs.target deskradar-lcd.service
Requires=deskradar-lcd.service

[Service]
Type=oneshot
User=root
ExecStart=/opt/deskradar-pi-services/.venv/bin/python /opt/deskradar-pi-services/scripts/boot_check.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target