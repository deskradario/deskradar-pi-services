[Unit]
Description=Plane Tracker LCD Service
After=local-fs.target
StartLimitIntervalSec=0
StartLimitBurst=0
StartLimitAction=none

[Service]
Type=simple
WorkingDirectory=/opt/deskradar-pi-services/lcd
ExecStart=/opt/deskradar-pi-services/.venv/bin/python -m app.main
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target